# PURPOSE: Template of all required environment variables — copy to .env and fill in values
# CALLED BY: Application startup via python-dotenv or Lambda environment config
# DEPENDS ON: Nothing — this is a reference file, not loaded directly

# AWS configuration
AWS_REGION=ap-south-1

# Bedrock model identifiers
BEDROCK_MODEL_ID=anthropic.claude-3-sonnet-20240229-v1:0
BEDROCK_EMBEDDING_MODEL_ID=amazon.titan-embed-text-v2:0

# OpenSearch Serverless
OPENSEARCH_ENDPOINT=https://your-collection-id.us-east-1.aoss.amazonaws.com
OPENSEARCH_INDEX=runbooks-index

# S3 source bucket
S3_BUCKET_NAME=your-runbooks-bucket

# Future vLLM integration (self-hosted model endpoint)
VLLM_API_URL=http://localhost:8000/v1

# HuggingFace — required for cross-encoder reranker model download
HUGGINGFACE_TOKEN=hf_your_token_here

# Lambda execution role ARN
LAMBDA_EXECUTION_ROLE_ARN=arn:aws:iam::537236558431:role/rag-lambda-ingestion-role

# RAG Ingestion Permmission
arn:aws:iam::537236558431:policy/rag-ingestion-permissions 
